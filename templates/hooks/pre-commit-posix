#!/usr/bin/env sh
#
# Pre-commit hook: Static security scan + delegate to .husky/pre-commit
#
# This file lives in .husky/_/ where Git's core.hooksPath points.
# The static scan is POSIX sh so it works in ALL Git clients (VS Code, terminal, etc).
# The AI review in .husky/pre-commit requires bash and only runs from terminal.
#

# ─── Static Pattern Scan (POSIX sh, works everywhere) ───────────────────────

CODE_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.(cs|ts|tsx|js|jsx|py|go|java|sql|css|scss)$' || true)
if [ -n "$CODE_FILES" ]; then
  STAGED_DIFF=$(printf '%s\n' "$CODE_FILES" | xargs git diff --cached -- 2>/dev/null)
else
  STAGED_DIFF=""
fi

if [ -z "$STAGED_DIFF" ]; then
  exit 0
fi

# Check added lines for SQL injection via string interpolation: $"...SELECT...{
SQL_HITS=$(printf '%s\n' "$STAGED_DIFF" | grep '^+' | grep -v '^+++' | grep -iE '\$"[^"]*\b(SELECT|INSERT|UPDATE|DELETE|DROP|ALTER|EXEC)\b[^"]*\{' || true)

# Check added lines for SQL injection via concatenation: "...SELECT..." +
SQL_CONCAT=$(printf '%s\n' "$STAGED_DIFF" | grep '^+' | grep -v '^+++' | grep -iE '"[^"]*\b(SELECT|INSERT|UPDATE|DELETE|DROP|ALTER|EXEC)\b[^"]*"\s*\+' || true)

if [ -n "$SQL_HITS" ] || [ -n "$SQL_CONCAT" ]; then
  echo ""
  echo "============================================================"
  echo "  COMMIT BLOCKED -- Static scan: SQL injection detected"
  echo "============================================================"
  echo ""
  if [ -n "$SQL_HITS" ]; then
    echo "  SEC-005 SQL injection (string interpolation):"
    printf '%s\n' "$SQL_HITS"
    echo ""
  fi
  if [ -n "$SQL_CONCAT" ]; then
    echo "  SEC-005 SQL injection (string concatenation):"
    printf '%s\n' "$SQL_CONCAT"
    echo ""
  fi
  echo "Fix the violations above and try again."
  echo "To bypass: git commit --no-verify (not recommended)"
  echo ""
  exit 1
fi

# ─── Delegate to full bash hook for AI review ───────────────────────────────

. "$(dirname "$0")/h"
